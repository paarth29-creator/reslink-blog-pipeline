# Copy this file to .env and fill in real values for local testing.
# Never commit the real .env file, it should stay out of git (see .gitignore).

OPENROUTER_API_KEY=
# Optional, defaults to a free DeepSeek model if left blank. Check
# https://openrouter.ai/models?max_price=0 for current free model IDs.
OPENROUTER_MODEL=

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=
# Optional, defaults to "post" if left blank.
SANITY_DOCUMENT_TYPE=

# Optional. Leave blank to skip Slack alerts (you'll still get GitHub
# Actions' automatic email-on-failure).
SLACK_WEBHOOK_URL=
